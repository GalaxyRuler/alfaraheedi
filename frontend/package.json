{
  "name": "alfaraheedi-frontend",
  "private": true,
  "version": "2.0.0-rc.1",
  "type": "module",
  "description": "Local-first writing workbench for the Nahou engine.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "desktop:build": "cd .. && frontend\\node_modules\\.bin\\tauri build --config src-tauri/tauri.conf.json && powershell -NoProfile -ExecutionPolicy Bypass -File scripts\\Copy-DesktopInstaller.ps1",
    "desktop:dev": "cd .. && frontend\\node_modules\\.bin\\tauri dev --config src-tauri/tauri.conf.json",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:e2e": "node ./scripts/build-e2e.mjs && playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@codemirror/commands": "^6.7.1",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.36.1",
    "@tauri-apps/api": "^2.11.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.61.0",
    "@tauri-apps/cli": "^2.11.3",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vite": "^6.0.5",
    "vitest": "^3.0.0"
  }
}
