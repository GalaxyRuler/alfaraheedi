{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Alfaraheedi",
  "version": "0.5.0",
  "identifier": "com.galaxyruler.alfaraheedi",
  "build": {
    "beforeDevCommand": "cd ../frontend && npm run dev -- --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "cd ../frontend && npm run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Alfaraheedi",
        "width": 860,
        "height": 620,
        "minWidth": 640,
        "minHeight": 480,
        "visible": true,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "GalaxyRuler",
    "category": "Productivity",
    "shortDescription": "Local-first writing companion",
    "longDescription": "Alfaraheedi is a local-first writing companion for Arabic and bilingual text."
  }
}
