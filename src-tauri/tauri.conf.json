{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nahou",
  "version": "2.0.0-rc.1",
  "identifier": "com.galaxyruler.nahou",
  "build": {
    "beforeDevCommand": "cd ../frontend && npm run dev -- --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "cd ../frontend && npm run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Nahou",
        "width": 860,
        "height": 620,
        "minWidth": 640,
        "minHeight": 480,
        "visible": true,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "publisher": "GalaxyRuler",
    "category": "Productivity",
    "shortDescription": "Local-first writing companion",
    "longDescription": "Nahou is a local-first writing companion for Arabic and bilingual text. Select text in another app, use the hotkey or tray action, review suggestions locally, then copy or replace through the desktop companion."
  }
}
